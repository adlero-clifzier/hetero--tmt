<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hetero.controller.SettingsController"
            fitToWidth="true" styleClass="scroll-pane">
    <VBox spacing="20" style="-fx-padding:28;" maxWidth="560">

        <!-- Account card -->
        <VBox styleClass="card" spacing="12">
            <Label text="Account" styleClass="form-title"/>
            <Separator/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <StackPane style="-fx-background-color:#14b8a6;-fx-background-radius:50;-fx-min-width:44;-fx-min-height:44;-fx-max-width:44;-fx-max-height:44;">
                    <Label text="H" style="-fx-text-fill:#0d0f14;-fx-font-size:18px;-fx-font-weight:bold;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label fx:id="lblUser" text="—" style="-fx-text-fill:#e2e8f0;-fx-font-size:14px;-fx-font-weight:bold;"/>
                    <Label text="Signed in" style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
                </VBox>
            </HBox>
            <Button text="Sign Out" styleClass="btn-sm-danger" onAction="#onLogout" style="-fx-padding:7 16;"/>
        </VBox>

        <!-- Appearance card -->
        <VBox styleClass="card" spacing="12">
            <Label text="Appearance" styleClass="form-title"/>
            <Separator/>
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Theme" style="-fx-text-fill:#e2e8f0;-fx-font-size:13px;"/>
                    <Label text="Switch between dark and light mode" style="-fx-text-fill:#6b7280;-fx-font-size:11px;"/>
                </VBox>
                <ToggleButton fx:id="tglTheme" text="Dark Mode" styleClass="toggle-button" onAction="#onToggleTheme"/>
            </HBox>
        </VBox>

        <!-- About card -->
        <VBox styleClass="card" spacing="8">
            <Label text="About" styleClass="form-title"/>
            <Separator/>
            <Label text="Hetero Task Management Tool" style="-fx-text-fill:#e2e8f0;-fx-font-size:13px;"/>
            <Label text="Version 1.0.0  ·  Java 17  ·  JavaFX 21  ·  SQLite" style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
            <Label text="Data Structures · HashMap · LinkedList · ArrayList" style="-fx-text-fill:#6b7280;-fx-font-size:12px;"/>
        </VBox>

    </VBox>
</ScrollPane>

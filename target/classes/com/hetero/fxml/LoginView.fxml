<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.hetero.controller.LoginController"
           styleClass="login-root" prefWidth="480" prefHeight="560">

    <VBox alignment="CENTER" spacing="0" maxWidth="380" maxHeight="520" styleClass="login-card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Brand -->
        <Label text="Hetero" styleClass="login-brand"/>
        <Label text="Task Management Tool" styleClass="login-sub"/>
        <VBox.margin><Insets bottom="28"/></VBox.margin>

        <!-- Tabs: Sign In / Register -->
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

            <!-- ── Sign In ── -->
            <Tab text="Sign In">
                <VBox spacing="14" style="-fx-padding:20 0 0 0;">
                    <VBox spacing="4">
                        <Label text="USERNAME" styleClass="field-label"/>
                        <TextField fx:id="tfLoginUser" promptText="Enter username"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="PASSWORD" styleClass="field-label"/>
                        <PasswordField fx:id="pfLoginPass" promptText="Enter password"/>
                    </VBox>
                    <Label fx:id="lblLoginError" styleClass="error-label" visible="false" managed="false" wrapText="true"/>
                    <Button fx:id="btnLogin" text="Sign In" styleClass="btn-accent"
                            onAction="#onLogin" maxWidth="Infinity" style="-fx-padding:10 0;"/>
                    <Label text="Default: admin / admin" style="-fx-text-fill:#374151;-fx-font-size:11px;" alignment="CENTER" maxWidth="Infinity"/>
                </VBox>
            </Tab>

            <!-- ── Register ── -->
            <Tab text="Create Account">
                <VBox spacing="12" style="-fx-padding:20 0 0 0;">
                    <VBox spacing="4">
                        <Label text="USERNAME" styleClass="field-label"/>
                        <TextField fx:id="tfRegUser" promptText="Choose a username"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="DISPLAY NAME" styleClass="field-label"/>
                        <TextField fx:id="tfRegDisplay" promptText="Your name (optional)"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="PASSWORD" styleClass="field-label"/>
                        <PasswordField fx:id="pfRegPass" promptText="Min 4 characters"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                        <PasswordField fx:id="pfRegConfirm" promptText="Repeat password"/>
                    </VBox>
                    <Label fx:id="lblRegError"   styleClass="error-label"   visible="false" managed="false" wrapText="true"/>
                    <Label fx:id="lblRegSuccess" styleClass="success-label" visible="false" managed="false" wrapText="true"/>
                    <Button text="Create Account" styleClass="btn-accent"
                            onAction="#onRegister" maxWidth="Infinity" style="-fx-padding:10 0;"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</StackPane>
